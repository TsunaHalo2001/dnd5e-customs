    "Thalamra Varhampur" -> "Consejo de los cuatro" [dir=none, label="pertenece a", color=green];

    "Thalamra Varhampur" -> "Morlock Varhampur" [label="madre", color=darkred];
    "Thalamra Varhampur" -> "Amrik Varhampur" [label="madre", color=darkred];
    "Thalamra Varhampur" -> "Tres muertos" [label="financia", color=darkgreen];
    "Thalamra Varhampur" -> "Zariel" [label="discipulo de", color=darkgreen, style="dashed"];
}