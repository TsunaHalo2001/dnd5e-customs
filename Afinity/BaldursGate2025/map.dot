Señor Supremo<br/>de los Nueve<br/>Infiernos
    >];
    "Thavius Kreeg" [
        color=red,
        style="filled, dashed",
        fillcolor=lightcoral,
        label=<<b>Thavius Kreeg</b><br/><br/>
Alto Superintendente
    >];
    "Ulder Ravengard" [
        color=red,
        style="filled",
        fillcolor=lightcoral,
        label=<<b>Ulder Ravengard</b><br/><br/>
Gran Duque de<br/>
Puerta de Baldur<br/>
Desaparecido
    >];
    "Belynne Stelmane" [
        color=red,
        style="filled",
