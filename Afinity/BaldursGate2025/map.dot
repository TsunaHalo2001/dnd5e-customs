        label=<<b>Yael</b><br/><br/>
General
    >];
    "Lulu" [
        color=red,
        style="filled, dashed",
        fillcolor=lightcoral,
        label=<<b>Lulu</b><br/><br/>
Almofante
    >];
    "Olanthius" [
        color=red,
        style="filled, dashed",
